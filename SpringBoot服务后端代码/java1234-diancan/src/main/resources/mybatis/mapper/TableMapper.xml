<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.java1234.mapper.TableMapper">

    <resultMap type="com.java1234.entity.Table" id="TableResult">
        <id property="id" column="id"/>
        <result property="number" column="table_name"/>
        <result property="qrcode" column="qr_code"/>
        <result property="state" column="state"/>
    </resultMap>

    <select id="list" parameterType="Map" resultMap="TableResult">
        select * from t_table
        <if test="start!=null and pageSize!=null">
            limit #{start},#{pageSize}
        </if>

    </select>

    <select id="getTotal" parameterType="Map" resultType="Long">
        select count(*) from t_table
    </select>

    <select id="getById" parameterType="Integer" resultMap="TableResult">
        select * from t_table where id = #{id}
    </select>


</mapper>
