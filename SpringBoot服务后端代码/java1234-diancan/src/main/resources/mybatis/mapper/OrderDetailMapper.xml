<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.java1234.mapper.OrderDetailMapper">

    <resultMap id="OrderDetailResult" type="com.java1234.entity.OrderDetail">
        <id property="id" column="id"/>
        <result property="order_id" column="order_id"/>
        <result property="dish_id" column="dish_id"/>
        <result property="quantity" column="quantity"/>
        <result property="price" column="price"/>
    </resultMap>

    <select id="listByOrderId" resultMap="OrderDetailResult" parameterType="java.lang.Integer">
        SELECT id,order_id,dish_id,quantity,price FROM t_order_detail WHERE order_id = #{orderId}
    </select>

    <select id="getDishSalesCount" resultType="java.util.HashMap">
        SELECT dish_id, SUM(quantity) as total FROM t_order_detail GROUP BY dish_id
    </select>

</mapper>
