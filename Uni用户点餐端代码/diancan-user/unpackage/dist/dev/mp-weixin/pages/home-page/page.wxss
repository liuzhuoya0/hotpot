/* 动画 */
.coup-anim.data-v-2f68e6da{
	-webkit-animation: coup-data-v-2f68e6da 0.3s ease-out;
	        animation: coup-data-v-2f68e6da 0.3s ease-out;
}
@-webkit-keyframes coup-data-v-2f68e6da{
0%{
		-webkit-transform: translateY(100%);
		        transform: translateY(100%);
}
100%{
		-webkit-transform: translateY(0);
		        transform: translateY(0);
}
}
@keyframes coup-data-v-2f68e6da{
0%{
		-webkit-transform: translateY(100%);
		        transform: translateY(100%);
}
100%{
		-webkit-transform: translateY(0);
		        transform: translateY(0);
}
}

