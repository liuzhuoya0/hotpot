<view class="service-request-view"><view class="content"><view class="section"><view class="section-title">选择服务类型</view><view class="type-list"><view data-event-opts="{{[['tap',[['selectType',['add_soup']]]]]}}" class="{{['type-item',(selectedType==='add_soup')?'active':'']}}" bindtap="__e"><view class="type-icon">🍲</view><view class="type-text">加汤</view></view><view data-event-opts="{{[['tap',[['selectType',['urge']]]]]}}" class="{{['type-item',(selectedType==='urge')?'active':'']}}" bindtap="__e"><view class="type-icon">⏰</view><view class="type-text">催菜</view></view><view data-event-opts="{{[['tap',[['selectType',['change_plate']]]]]}}" class="{{['type-item',(selectedType==='change_plate')?'active':'']}}" bindtap="__e"><view class="type-icon">🍽️</view><view class="type-text">换碟</view></view><view data-event-opts="{{[['tap',[['selectType',['other']]]]]}}" class="{{['type-item',(selectedType==='other')?'active':'']}}" bindtap="__e"><view class="type-icon">❓</view><view class="type-text">其他</view></view></view></view><view class="section"><view class="section-title">补充说明（选填）</view><textarea class="textarea" placeholder="请输入详细说明..." maxlength="200" data-event-opts="{{[['input',[['__set_model',['','content','$event',[]]]]]]}}" value="{{content}}" bindinput="__e"></textarea></view><view class="section"><view class="section-title">我的服务请求</view><block wx:if="{{$root.g0>0}}"><view><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="request-item"><view class="request-header"><view class="request-type">{{item.m0}}</view><view class="{{['request-status','status-'+item.$orig.state]}}">{{''+item.m1+''}}</view></view><block wx:if="{{item.$orig.content}}"><view class="request-content">{{item.$orig.content}}</view></block><view class="request-time">{{item.m2}}</view><block wx:if="{{item.$orig.state===2&&item.$orig.handleRemark}}"><view class="request-remark">{{'服务员备注：'+item.$orig.handleRemark+''}}</view></block></view></block></view></block><block wx:else><view class="empty-tip">暂无服务请求</view></block></view></view><view data-event-opts="{{[['tap',[['submitRequest',['$event']]]]]}}" class="submit-btn" bindtap="__e">提交请求</view></view>