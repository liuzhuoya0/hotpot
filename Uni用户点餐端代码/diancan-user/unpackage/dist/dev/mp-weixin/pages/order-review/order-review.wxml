<view class="review-view"><view class="review-content"><view class="section"><view class="section-title">评分</view><view class="score-item"><text class="score-label">火锅锅底口味</text><view class="stars"><block wx:for="{{5}}" wx:for-item="i" wx:for-index="__i0__" wx:key="*this"><view data-event-opts="{{[['tap',[['setScore',['potTaste','$0'],[[[5,'',__i0__]]]]]]]}}" class="{{['star',i<=potTasteScore?'active':'']}}" bindtap="__e"> ★ </view></block></view></view><view class="score-item"><text class="score-label">菜品新鲜度</text><view class="stars"><block wx:for="{{5}}" wx:for-item="i" wx:for-index="__i1__" wx:key="*this"><view data-event-opts="{{[['tap',[['setScore',['dishFreshness','$0'],[[[5,'',__i1__]]]]]]]}}" class="{{['star',i<=dishFreshnessScore?'active':'']}}" bindtap="__e"> ★ </view></block></view></view><view class="score-item"><text class="score-label">用餐体验</text><view class="stars"><block wx:for="{{5}}" wx:for-item="i" wx:for-index="__i2__" wx:key="*this"><view data-event-opts="{{[['tap',[['setScore',['diningExperience','$0'],[[[5,'',__i2__]]]]]]]}}" class="{{['star',i<=diningExperienceScore?'active':'']}}" bindtap="__e"> ★ </view></block></view></view></view><view class="section"><view class="section-title">文字评价</view><textarea class="textarea" placeholder="请输入您的评价..." maxlength="500" data-event-opts="{{[['input',[['__set_model',['','content','$event',[]]]]]]}}" value="{{content}}" bindinput="__e"></textarea></view><view class="section"><view class="section-title">上传图片</view><view class="image-list"><block wx:for="{{images}}" wx:for-item="img" wx:for-index="index" wx:key="index"><view class="image-item"><image src="{{img}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',[index]]]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['deleteImage',[index]]]]]}}" class="delete-btn" bindtap="__e">×</view></view></block><block wx:if="{{$root.g0<9}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="upload-btn" bindtap="__e"><text class="upload-icon">+</text><text>上传图片</text></view></block></view></view></view><view data-event-opts="{{[['tap',[['submitReview',['$event']]]]]}}" class="submit-btn" bindtap="__e">提交评价</view></view>