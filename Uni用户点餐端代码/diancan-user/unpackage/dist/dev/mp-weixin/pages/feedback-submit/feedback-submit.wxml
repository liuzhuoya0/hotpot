<view class="feedback-view"><view class="header"></view><view class="feedback-content"><view class="section"><view class="section-title">反馈类型</view><view class="type-list"><view data-event-opts="{{[['tap',[['setFeedbackType',['complaint']]]]]}}" class="{{['type-item',(feedbackType==='complaint')?'active':'']}}" bindtap="__e"><text class="type-icon">😠</text><text class="type-text">投诉</text></view><view data-event-opts="{{[['tap',[['setFeedbackType',['suggestion']]]]]}}" class="{{['type-item',(feedbackType==='suggestion')?'active':'']}}" bindtap="__e"><text class="type-icon">💡</text><text class="type-text">建议</text></view></view></view><view class="section"><view class="section-title">反馈内容</view><textarea class="textarea" placeholder="请详细描述您的问题或建议..." maxlength="500" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['','content','$event',[]]]]]]}}" value="{{content}}" bindinput="__e"></textarea><view class="char-count">{{$root.g0+"/500"}}</view></view></view><view data-event-opts="{{[['tap',[['submitFeedback',['$event']]]]]}}" class="{{['submit-btn',(!canSubmit)?'disabled':'']}}" bindtap="__e"><text>提交反馈</text></view></view>