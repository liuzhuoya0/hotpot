<view class="review-list-view"><view class="header"></view><block wx:if="{{$root.g0>0}}"><view class="review-list"><block wx:for="{{$root.l1}}" wx:for-item="review" wx:for-index="__i0__" wx:key="id"><view class="review-card"><view class="review-header"><view class="review-id">{{"评价 #"+review.$orig.id}}</view><view class="review-time">{{review.m0}}</view></view><view class="review-divider"></view><view class="review-content"><view class="score-section"><view class="score-item"><text class="score-label">火锅锅底口味</text><view class="stars"><block wx:for="{{5}}" wx:for-item="i" wx:for-index="__i1__" wx:key="*this"><view class="{{['star',i<=review.$orig.potTasteScore?'active':'']}}"> ★ </view></block></view></view><view class="score-item"><text class="score-label">菜品新鲜度</text><view class="stars"><block wx:for="{{5}}" wx:for-item="i" wx:for-index="__i2__" wx:key="*this"><view class="{{['star',i<=review.$orig.dishFreshnessScore?'active':'']}}"> ★ </view></block></view></view><view class="score-item"><text class="score-label">用餐体验</text><view class="stars"><block wx:for="{{5}}" wx:for-item="i" wx:for-index="__i3__" wx:key="*this"><view class="{{['star',i<=review.$orig.diningExperienceScore?'active':'']}}"> ★ </view></block></view></view></view><block wx:if="{{review.$orig.content}}"><view class="content-section"><view class="content-label">评价内容</view><view class="content-text">{{review.$orig.content}}</view></view></block><block wx:if="{{review.g1}}"><view class="image-section"><view class="image-label">评价图片</view><view class="image-list"><block wx:for="{{review.l0}}" wx:for-item="img" wx:for-index="index" wx:key="index"><view class="image-item"><image src="{{baseUrl+img}}" mode="aspectFill" data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({review:review.$orig,index})}}" bindtap="__e"></image></view></block></view></view></block></view></view></block></view></block><block wx:else><view class="empty-state"><view class="empty-icon">⭐</view><view class="empty-text">暂无评价</view><view class="empty-subtext">快去发表评价吧~</view></view></block></view>